PORT=5000
NODE_ENV=development

# MongoDB — MONGODB_ATLAS_URL 이 있으면 Atlas 사용, 없으면 MONGODB_URI → 없으면 로컬 기본값
# MONGODB_ATLAS_URL=mongodb+srv://USER:PASS@cluster.../dbname
MONGODB_URI=mongodb://127.0.0.1:27017/shopping-mall

# 포트원 V2 결제 검증
# 관리자 콘솔 > 결제연동 > 연동 관리 > 식별코드·API Keys > V2 API > "새로운 API Secret 발급"
PORTONE_V2_API_SECRET=
