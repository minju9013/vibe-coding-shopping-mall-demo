# 백엔드 API (선택, 기본 http://localhost:5000/api)
# VITE_API_URL=http://localhost:5000/api

# Cloudinary 업로드 위젯 (상품 이미지)
# Vite는 VITE_ 로 시작하는 변수만 브라우저 코드에 노출합니다.
#
# Cloud name: https://console.cloudinary.com 대시보드
# Upload preset: Settings → Upload → Upload presets → Add upload preset
#               Signing mode: Unsigned (위젯 unsigned 업로드용)

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# 포트원 V2 결제 연동
# storeId: 포트원 관리자 콘솔 > 결제연동 > 연동 관리 > 식별코드·API Keys
# channelKey: 포트원 관리자 콘솔 > 결제연동 > 채널 관리
VITE_PORTONE_STORE_ID=
VITE_PORTONE_CHANNEL_KEY=
